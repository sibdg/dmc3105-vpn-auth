SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong_admin_password

HYSTERIA_CONFIG_PATH=/etc/hysteria/config.yaml
# Command runs inside backend container. Leave empty to skip automatic reload.
HYSTERIA_RELOAD_COMMAND=
# address in hysteria config for clients to connect to
REGISTRATION_BASE_URL=https://hs2.domain.com:443

SMTP_HOST=smtp.mail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_login
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=user@domain.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

DATABASE_URL=sqlite:///./data/vpn_auth.db
API_PREFIX=/api
# If nginx forwards /vpn-auth/api/... without URI rewrite:
PROXY_PATH_PREFIX=

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
AUTH_COOKIE_NAME=vpn_admin_access
CSRF_COOKIE_NAME=vpn_admin_csrf
USER_AUTH_COOKIE_NAME=vpn_user_access
USER_CSRF_COOKIE_NAME=vpn_user_csrf
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

ADMIN_LOGIN_WINDOW_SECONDS=300
ADMIN_MAX_ATTEMPTS=5
ADMIN_LOCKOUT_SECONDS=600

VERIFY_CODE_EXPIRE_MINUTES=15
VERIFY_REQUEST_COOLDOWN_SECONDS=60
HYSTERIA_USERPASS_LENGTH=32

CORS_ALLOW_ORIGINS=http://domain:5173,https://domain.com
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type
CORS_ALLOW_CREDENTIALS=true