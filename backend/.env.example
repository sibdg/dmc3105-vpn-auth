APP_NAME=VPN Auth Service
API_PREFIX=/api
DATABASE_URL=sqlite:///./vpn_auth.db
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
AUTH_COOKIE_NAME=vpn_admin_access
CSRF_COOKIE_NAME=vpn_admin_csrf
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong_admin_password
ADMIN_LOGIN_WINDOW_SECONDS=300
ADMIN_MAX_ATTEMPTS=5
ADMIN_LOCKOUT_SECONDS=600

SMTP_HOST=smtp.mail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_login
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=user@domain.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

VERIFY_CODE_EXPIRE_MINUTES=15
VERIFY_REQUEST_COOLDOWN_SECONDS=60
HYSTERIA_CONFIG_PATH=/etc/hysteria/config.yaml
HYSTERIA_RELOAD_COMMAND=systemctl restart hysteria-server.service
HYSTERIA_USERPASS_LENGTH=32
REGISTRATION_BASE_URL=hs2.domain.com:443

CORS_ALLOW_ORIGINS=http://domain:5173,https://domain.com
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type
CORS_ALLOW_CREDENTIALS=true
