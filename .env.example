# where is your hysteria config file located on the host
HYSTERIA_CONFIG_HOST_PATH=/etc/hysteria/config.yaml
# must be equal to backend .env HYSTERIA_CONFIG_PATH
HYSTERIA_CONFIG_CONTAINER_PATH=/etc/hysteria/config.yaml

FRONTEND_HOST_PORT=18080
BACKEND_HOST_PORT=18000

VITE_API_BASE=/vpn-auth/api
VITE_ROUTER_BASENAME=/vpn-auth
VITE_APP_NAME=VPN Auth Service
VITE_HYSTERIA_URI_TAG=VPN Auth
